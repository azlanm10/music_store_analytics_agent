import pandas as pd
import matplotlib.pyplot as plt

# Execute the SQL query to get the top 5 artists by revenue
sql_query = """
SELECT 
    artist.name AS artist_name,
    SUM(invoice.total) AS total_revenue
FROM 
    artist
JOIN 
    album ON artist.artist_id = album.artist_id
JOIN 
    track ON album.album_id = track.album_id
JOIN 
    invoice_line ON track.track_id = invoice_line.track_id
JOIN 
    invoice ON invoice_line.invoice_id = invoice.invoice_id
GROUP BY 
    artist.name
ORDER BY 
    total_revenue DESC
LIMIT 5;
"""
revenue_per_artist = execute_sql_query(sql_query)

# Plotting the top 5 artists by revenue
plt.figure(figsize=(10,6))
plt.bar(revenue_per_artist['artist_name'], revenue_per_artist['total_revenue'], color='skyblue')
plt.title('Top 5 Artists by Revenue')
plt.xlabel('Artist Name')
plt.ylabel('Total Revenue')
plt.xticks(rotation=45)
plt.grid(axis='y')

# Save the plot as a file
plot_file = "top_5_artists_revenue.png"
plt.savefig(plot_file)
plt.close()  # Close the plot to free up memory

# Declare the result variable with plot information
result = {'type': 'plot', 'value': plot_file}
