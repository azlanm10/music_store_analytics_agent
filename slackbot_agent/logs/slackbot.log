import pandas as pd
import matplotlib.pyplot as plt

# Execute the SQL query to get the top 5 artists with the most albums
sql_query = """
SELECT a.artist_id, a.name, COUNT(al.album_id) AS album_count
FROM artist a
JOIN album al ON a.artist_id = al.artist_id
GROUP BY a.artist_id, a.name
ORDER BY album_count DESC
LIMIT 5;
"""
result_df = execute_sql_query(sql_query)

# Plotting the results
plt.figure(figsize=(10, 6))
plt.bar(result_df['name'], result_df['album_count'], color='skyblue')
plt.title('Top 5 Artists with Most Albums')
plt.xlabel('Artist Name')
plt.ylabel('Number of Albums')
plt.xticks(rotation=45)
plt.tight_layout()

# Save the plot to a file
plt.savefig('top_5_artists_with_most_albums.png')
plt.close()

# Prepare the result
