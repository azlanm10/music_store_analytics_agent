import pandas as pd

# Query to get the artists with the most albums
sql_query = """
SELECT a.name AS artist_name, COUNT(al.album_id) AS album_count
FROM artist a
JOIN album al ON a.artist_id = al.artist_id
GROUP BY a.artist_id
ORDER BY album_count DESC
LIMIT 5; 
"""

