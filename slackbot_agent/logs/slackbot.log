import pandas as pd
import matplotlib.pyplot as plt

# SQL query to get the top 5 artists with the most albums
sql_query = """
SELECT a.artist_id, a.name, COUNT(al.album_id) AS album_count
FROM artist a
JOIN album al ON a.artist_id = al.artist_id
GROUP BY a.artist_id, a.name
ORDER BY album_count DESC
LIMIT 5;
"""
result_df = execute_sql_query(sql_query)

# Plotting the top 5 artists with most albums
plt.figure(figsize=(10, 6))
plt.barh(result_df['name'], result_df['album_count'], color='skyblue')
plt.xlabel('Number of Albums')
plt.title('Top 5 Artists with Most Albums')
plt.gca().invert_yaxis()  # Invert y axis to have the artist with the most albums on top
plt.savefig("top_artists_albums_chart.png")
plt.close()  # Close the plot to free up memory

# Declaring the result variable
result = {'type': 'plot', 'value': "top_artists_albums_chart.png"}
