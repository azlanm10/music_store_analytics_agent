import pandas as pd

# SQL query to find the artist with the most albums
sql_query = """
SELECT artist.name AS artist_name, COUNT(album.album_id) AS album_count
FROM artist
JOIN album ON artist.artist_id = album.artist_id
GROUP BY artist.artist_id
ORDER BY album_count DESC
LIMIT 1;
"""

# Execute the SQL query
most_albums_df = execute_sql_query(sql_query)

# Extract the artist name with the maximum albums
max_albums_artist_name = most_albums_df['artist_name'].iloc[0]
max_albums_count = most_albums_df['album_count'].iloc[0]

# Result declaration
result = {
    "type": "string",
    "value": f"The artist with the most albums is {max_albums_artist_name} with {max_albums_count} albums."
}
