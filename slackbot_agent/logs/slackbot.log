import pandas as pd
import matplotlib.pyplot as plt

# SQL query to calculate revenue generated by each artist
sql_query_summary = """
SELECT 
    a.artist_id, 
    a.name AS artist_name, 
    COUNT(DISTINCT al.album_id) AS total_albums, 
    COUNT(t.track_id) AS total_tracks, 
    SUM(t.unit_price) AS total_revenue
FROM artist a
JOIN album al ON a.artist_id = al.artist_id
JOIN track t ON al.album_id = t.album_id
GROUP BY a.artist_id, a.name;
"""

# Execute the SQL query and get the summary DataFrame
summary_df = execute_sql_query(sql_query_summary)

# Check if the summary_df is not empty
if not summary_df.empty:
    # Create revenue histogram
    plt.figure(figsize=(10, 6))
    
    # Create bins for the histogram
    bins = pd.cut(summary_df['total_revenue'], bins=10)
    
    # Count occurrences in each bin
    revenue_counts = bins.value_counts().sort_index()
    
    # Plotting the histogram
    revenue_counts.plot(kind='bar', color='skyblue')
    
    plt.xlabel('Revenue Ranges ($)')
    plt.ylabel('Number of Artists')
    plt.title('Histogram of Revenue Generated by Artists in the Music Store')
    
    # Save the histogram plot image
    chart_filename = 'exports\\charts\\temp_histogram_chart.png'
    plt.savefig(chart_filename)
    plt.close()
    
    # Create a result summary string (optional)
    result_summary = ', '.join([f"{row['artist_name']} has {row['total_albums']} albums and {row['total_tracks']} tracks, generating a revenue of ${row['total_revenue']:.2f}" for index, row in summary_df.iterrows()])
    
    # Declare result variable with the histogram plot
    result = {'type': 'plot', 'value': chart_filename}
else:
    result = {'type': 'string', 'value': 'No data found in the music store database.'}
