import pandas as pd
import matplotlib.pyplot as plt

# Query to get the revenue per artist
sql_query = """
SELECT ar.artist_id, ar.name, SUM(invo.total) AS total_revenue
FROM artist ar
JOIN album al ON ar.artist_id = al.artist_id
JOIN track tr ON al.album_id = tr.album_id
JOIN invoice_line inv_line ON tr.track_id = inv_line.track_id
JOIN invoice invo ON inv_line.invoice_id = invo.invoice_id
GROUP BY ar.artist_id, ar.name
ORDER BY total_revenue DESC
LIMIT 5;
"""

# Execute the SQL query and get the result
result_df = execute_sql_query(sql_query)

# Plotting the total revenue for the top artists
plt.figure(figsize=(10, 6))
plt.barh(result_df['name'], result_df['total_revenue'], color='lightgreen')
plt.xlabel('Total Revenue')
plt.ylabel('Artist Name')
plt.title('Top 5 Artists by Revenue')
plt.gca().invert_yaxis()  # Invert y-axis to show the artist with the highest revenue on top
plt.savefig('exports\\charts\\temp_chart_revenue.png')
plt.close()

# Declare the result variable
result = {'type': 'plot', 'value': 'exports\\charts\\temp_chart_revenue.png'}
