import pandas as pd
import matplotlib.pyplot as plt

# Query to get the artist with the most songs
sql_query = """
SELECT artist.name, COUNT(track.track_id) as song_count
FROM track
JOIN album ON track.album_id = album.album_id
JOIN artist ON album.artist_id = artist.artist_id
GROUP BY artist.artist_id
ORDER BY song_count DESC
LIMIT 5
"""

result_df = execute_sql_query(sql_query)

# Plotting the results
plt.figure(figsize=(10, 6))
plt.bar(result_df['name'], result_df['song_count'], color='skyblue')
plt.title('Top 5 Artists with the Highest Number of Songs')
plt.xlabel('Artist Name')
plt.ylabel('Number of Songs')
plt.xticks(rotation=45)
plt.tight_layout()
plt.savefig('exports\\charts\\temp_chart_artist_songs.png')
result = {'type': 'plot', 'value': 'exports\\charts\\temp_chart_artist_songs.png'}
