# TODO: import the required dependencies
import pandas as pd

# Query to find artists with the most albums
sql_query = """
SELECT 
    a.artist_id,
    ar.name AS artist_name,
    COUNT(a.album_id) AS album_count
FROM 
    album a
JOIN 
    artist ar ON a.artist_id = ar.artist_id
GROUP BY 
    a.artist_id, ar.name
ORDER BY 
    album_count DESC
"""

# Execute the SQL query
