import pandas as pd
import matplotlib.pyplot as plt

# SQL query to calculate revenue by each artist
sql_query = """
SELECT 
    ar.artist_id,
    ar.name AS artist_name,
    SUM(il.unit_price * il.quantity) AS revenue
FROM 
    invoice_line il
JOIN 
    invoice i ON il.invoice_id = i.invoice_id
JOIN 
    track t ON il.track_id = t.track_id
JOIN 
    album a ON t.album_id = a.album_id
JOIN 
    artist ar ON a.artist_id = ar.artist_id
GROUP BY 
    ar.artist_id, ar.name
ORDER BY 
    revenue DESC
"""

# Execute the SQL query and retrieve the results
result_df = execute_sql_query(sql_query)

# Create a bar chart for revenue by artist
plt.figure(figsize=(10, 6))
plt.bar(result_df['artist_name'], result_df['revenue'], color='lightgreen')
plt.title('Revenue by Artist')
plt.xlabel('Artist Name')
plt.ylabel('Revenue ($)')
plt.xticks(rotation=45)
plt.grid(axis='y', linestyle='--', alpha=0.7)

# Save the plot to a file
plot_file = 'exports\\charts\\temp_chart_8903376e-c88a-4d10-9b2e-b083a4107f8c.png'
plt.savefig(plot_file)
plt.close()

# Prepare the result variable as a dictionary for output
result = {'type': 'plot', 'value': plot_file}
