import pandas as pd
import matplotlib.pyplot as plt

# Execute SQL query to get total revenue per artist
sql_query = """
SELECT 
    a.artist_id, 
    a.name AS artist_name, 
    SUM(il.quantity * il.unit_price) AS total_revenue
FROM 
    artist a
JOIN 
    album al ON a.artist_id = al.artist_id
JOIN 
    track t ON al.album_id = t.album_id
JOIN 
    invoice_line il ON t.track_id = il.track_id
JOIN 
    invoice i ON il.invoice_id = i.invoice_id
GROUP BY 
    a.artist_id, a.name
ORDER BY 
    total_revenue DESC
LIMIT 5;
"""
revenue_per_artist_df = execute_sql_query(sql_query)

# Create a bar chart for the top 5 artists by revenue
plt.figure(figsize=(10, 6))
plt.bar(revenue_per_artist_df['artist_name'], revenue_per_artist_df['total_revenue'], color='skyblue')
plt.title('Top 5 Artists by Revenue')
plt.xlabel('Artists')
plt.ylabel('Total Revenue')
plt.xticks(rotation=45)
plt.tight_layout()

# Save the plot
chart_file_path = 'top_5_artists_by_revenue.png'
plt.savefig(chart_file_path)
plt.close()

# Declare result as a dictionary
