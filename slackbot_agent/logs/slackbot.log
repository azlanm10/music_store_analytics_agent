import pandas as pd

# Query to fetch summary information about artists, albums, and tracks.
sql_query_summary = """
SELECT 
    a.artist_id, 
    a.name AS artist_name, 
    COUNT(DISTINCT al.album_id) AS total_albums, 
    COUNT(t.track_id) AS total_tracks, 
    SUM(t.unit_price) AS total_revenue
FROM artist a
JOIN album al ON a.artist_id = al.artist_id
JOIN track t ON al.album_id = t.album_id
GROUP BY a.artist_id, a.name
ORDER BY total_revenue DESC;
"""

summary_df = execute_sql_query(sql_query_summary)

# If there are records, generate a string summarizing the results
if not summary_df.empty:
    result_summary = ", ".join(
        [f"{row['artist_name']} has {row['total_albums']} albums and {row['total_tracks']} tracks, generating a revenue of ${row['total_revenue']:.2f}" 
         for index, row in summary_df.iterrows()]
    )
    result = {'type': 'string', 'value': result_summary}
else:
    result = {'type': 'string', 'value': "No data found in the music store database."}
