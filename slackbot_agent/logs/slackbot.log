import pandas as pd

# Query to get the artists with the most albums
sql_query = """
SELECT 
    artist.name AS artist_name,
    COUNT(album.album_id) AS album_count
FROM 
    artist
JOIN 
    album ON artist.artist_id = album.artist_id
GROUP BY 
    artist.name
ORDER BY 
    album_count DESC
LIMIT 5;
"""

# Execute the SQL query
