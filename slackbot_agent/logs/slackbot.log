plt.title('Top 5 Artists with the Most Albums')
plt.xlabel('Artist Name')
plt.ylabel('Number of Albums')
plt.xticks(rotation=45)
plt.tight_layout()
plt.savefig('top_artists_albums.png')  # Save the plot as a PNG file
