# TODO: import the required dependencies
import pandas as pd

# SQL query to calculate revenue per artist
sql_query = """
SELECT 
    a.artist_id, 
    a.name AS artist_name, 
    SUM(il.quantity * il.unit_price) AS total_revenue
FROM 
    artist a
JOIN 
    album al ON a.artist_id = al.artist_id
JOIN 
    track t ON al.album_id = t.album_id
JOIN 
    invoice_line il ON t.track_id = il.track_id
JOIN 
    invoice i ON il.invoice_id = i.invoice_id
GROUP BY 
    a.artist_id, a.name
ORDER BY 
    total_revenue DESC;
"""

# Execute the SQL query and get the result as a DataFrame
revenue_per_artist_df = execute_sql_query(sql_query)

# Declare result var:
result = {
    "type": "dataframe",
    "value": revenue_per_artist_df
