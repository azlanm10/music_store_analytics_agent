import pandas as pd

# Existing code to get artists in the Rock genre
sql_query = """
SELECT DISTINCT a.artist_id, a.name
FROM artist a
JOIN album al ON a.artist_id = al.artist_id
JOIN track t ON al.album_id = t.album_id
JOIN genre g ON t.genre_id = g.genre_id
WHERE g.name = 'Rock'
ORDER BY a.artist_id;
"""

artists_rock_df = execute_sql_query(sql_query)

# New query to find which album has the most revenue
sql_query_revenue = """
SELECT al.title, SUM(il.unit_price * il.quantity) AS total_revenue
FROM album al
JOIN track t ON al.album_id = t.album_id
JOIN invoice_line il ON t.track_id = il.track_id
GROUP BY al.title
ORDER BY total_revenue DESC
LIMIT 1;
"""

most_revenue_album_df = execute_sql_query(sql_query_revenue)

# Extracting the album title with the highest revenue
