import pandas as pd

# SQL query to find the artist with the highest number of albums
sql_query = """
SELECT artist.name, COUNT(album.album_id) as album_count
FROM album
JOIN artist ON album.artist_id = artist.artist_id
GROUP BY artist.artist_id
HAVING COUNT(album.album_id) = (
    SELECT MAX(album_count)
    FROM (
        SELECT COUNT(album_id) as album_count
        FROM album
        GROUP BY artist_id
    ) as subquery
)
"""

