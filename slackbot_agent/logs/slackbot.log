import pandas as pd
import matplotlib.pyplot as plt

sql_query = """
SELECT EXTRACT(YEAR FROM i.invoice_date) AS year, 
       SUM(il.unit_price * il.quantity) AS total_revenue
FROM invoice_line il
JOIN invoice i ON il.invoice_id = i.invoice_id
JOIN track t ON il.track_id = t.track_id
JOIN album a ON t.album_id = a.album_id
JOIN genre g ON t.genre_id = g.genre_id
WHERE g.name = 'Rock'
AND EXTRACT(YEAR FROM i.invoice_date) >= EXTRACT(YEAR FROM CURRENT_DATE) - 5
GROUP BY year
ORDER BY year;
"""

result_df = execute_sql_query(sql_query)

# Plotting the total revenue for the rock genre per year
plt.figure(figsize=(10, 6))
plt.bar(result_df['year'], result_df['total_revenue'], color='blue')
plt.xlabel('Year')
plt.ylabel('Total Revenue')
plt.title('Total Revenue for Rock Genre per Year for the Past 5 Years')
plt.xticks(result_df['year'])
plt.grid(axis='y')

# Save the plot as a file
chart_filename = 'rock_genre_revenue_chart.png'
plt.savefig(chart_filename)
plt.close()

result = {'type': 'plot', 'value': chart_filename}
