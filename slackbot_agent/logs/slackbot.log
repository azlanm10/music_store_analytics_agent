import pandas as pd
import matplotlib.pyplot as plt

# Define the SQL query to get the top 5 artists with the most albums
sql_query = """
SELECT 
    ar.artist_id,
    ar.name AS artist_name,
    COUNT(a.album_id) AS album_count
FROM 
    album a
JOIN 
    artist ar ON a.artist_id = ar.artist_id
GROUP BY 
    ar.artist_id, ar.name
ORDER BY 
    album_count DESC
LIMIT 5
"""
# Execute the SQL query and store the result in a DataFrame
result_df = execute_sql_query(sql_query)

# Plotting the result
plt.figure(figsize=(10, 6))
plt.bar(result_df['artist_name'], result_df['album_count'], color='skyblue')
plt.title('Top 5 Artists with Most Albums')
plt.xlabel('Artist Name')
plt.ylabel('Number of Albums')
plt.xticks(rotation=45)
plt.grid(axis='y', linestyle='--', alpha=0.7)

# Save the plot as a file
plot_file = 'top_5_artists_with_most_albums.png'
plt.savefig(plot_file)
plt.close()

# Prepare the result variable
result = {'type': 'plot', 'value': plot_file}
