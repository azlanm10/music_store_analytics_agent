import pandas as pd
import matplotlib.pyplot as plt

# SQL Query to fetch top 5 artists by revenue
sql_query = """
SELECT 
    a.artist_id,
    ar.name AS artist_name,
    SUM(il.unit_price * il.quantity) AS total_revenue
FROM 
    invoice_line il
JOIN 
    track t ON il.track_id = t.track_id
JOIN 
    album a ON t.album_id = a.album_id
JOIN 
    artist ar ON a.artist_id = ar.artist_id
GROUP BY 
    a.artist_id, ar.name
ORDER BY 
    total_revenue DESC
LIMIT 5
"""

# Execute the SQL query
revenue_per_artist_df = execute_sql_query(sql_query)

# Generate a plot for the top 5 artists by revenue
plt.figure(figsize=(10, 6))
plt.bar(revenue_per_artist_df['artist_name'], revenue_per_artist_df['total_revenue'], color='skyblue')
plt.title('Top 5 Artists by Revenue')
plt.xlabel('Artist Name')
plt.ylabel('Total Revenue')
plt.xticks(rotation=45)
plt.tight_layout()

# Save the plot as a PNG file
chart_file = "top_5_artists_by_revenue.png"
plt.savefig(chart_file)

# Declare the result variable
result = {'type': 'plot', 'value': chart_file}
